datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String              @id @default(cuid())
  name          String?
  email         String?             @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  emails        Email[]
  preferences   UserPreference?
  workflows     Workflow[]
  webhooks      WebhookConnection[]
}

model WebhookConnection {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  url            String
  method         String    @default("POST") // POST or GET
  headers        String? // JSON object of custom headers
  emoji          String    @default("🔗")
  secret         String? // Optional signing secret (HMAC)
  lastTestedAt   DateTime?
  lastTestStatus String? // "success" | "error"
  lastTestCode   Int? // HTTP status code of last test
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
}

model Workflow {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  enabled       Boolean   @default(true)
  schedule      String // Cron expression e.g. "0 8 * * *"
  timezone      String    @default("UTC")
  actions       String // JSON array of action step configs
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  lastRunStatus String? // "success" | "error" | "running"
  lastRunLog    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([nextRunAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPreference {
  id             String @id @default(cuid())
  userId         String @unique
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories     String @default("Newsletters,Job / Recruitment,Finance,Notifications,Personal,Work / Professional") // comma-separated
  dedupWindowHrs Int    @default(168) // 1 week
  summaryModel   String @default("gemini-3.5-flash") // Default model
  chatModel      String @default("gemini-3.5-flash")
}

model Email {
  id             String   @id // Gmail message ID
  threadId       String // Gmail thread ID
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject        String
  sender         String
  receiver       String
  date           DateTime
  bodySnippet    String // Short preview snippet
  bodyContent    String // Stored raw body (plain text)
  htmlContent    String? // Stored HTML body if available
  unsubscribeUrl String? // Link or mailto for unsubscribing
  labels         String // Comma-separated labels from Gmail
  isDuplicate    Boolean  @default(false)
  dedupHash      String? // The hash for dedup checks

  summary EmailSummary?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threadId])
  @@index([userId])
}

model EmailSummary {
  id               String  @id @default(cuid())
  emailId          String  @unique
  email            Email   @relation(fields: [emailId], references: [id], onDelete: Cascade)
  shortSummary     String
  detailedSummary  String
  actionItems      String // JSON stringified list of action items
  category         String // e.g. Important, Finance, Promotion, etc.
  importanceScore  Int // 1-10
  replySuggestions String? // JSON stringified list of dynamic reply suggestions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SyncState {
  id            String   @id @default(cuid())
  userId        String   @unique
  lastHistoryId String?
  lastSyncAt    DateTime @default(now())
}

/// RAG Query Cache — stores normalized query hashes → AI answers per user
/// Avoids re-calling LLM for semantically identical queries (TTL: 24h default)
model QueryCache {
  id        String   @id @default(cuid())
  userId    String
  queryHash String // SHA-256 of normalized query string
  queryText String // Original query for debugging
  answer    String // Cached LLM answer
  hitCount  Int      @default(0) // Number of times this cache entry was used
  createdAt DateTime @default(now())
  expiresAt DateTime // Cache TTL — default 24h from creation

  @@unique([userId, queryHash])
  @@index([userId])
  @@index([expiresAt])
}

/// Per-user rate limiting state — sliding window counters
model RateLimit {
  id           String   @id @default(cuid())
  userId       String   @unique
  windowStart  DateTime @default(now())
  requestCount Int      @default(0)
}
